<div class="footer-bos" aria-hidden="true">
  <svg viewBox="0 0 1200 72" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path fill="#01271D" d="M0,72 L0,48 L25,48 L40,20 L55,48 L85,48 L105,8 L125,48 L160,48 L180,30 L200,48 L240,48 L262,4 L284,48 L320,48 L340,26 L360,48 L400,48 L422,14 L444,48 L485,48 L505,34 L525,48 L565,48 L590,2 L615,48 L655,48 L675,22 L695,48 L735,48 L755,38 L775,48 L815,48 L838,10 L861,48 L900,48 L920,30 L940,48 L980,48 L1005,16 L1030,48 L1070,48 L1090,26 L1110,48 L1150,48 L1170,36 L1190,48 L1200,48 L1200,72 Z"/>
